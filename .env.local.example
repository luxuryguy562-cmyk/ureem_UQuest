# U-Quest 환경변수 템플릿
# 이 파일을 복사해서 같은 폴더에 ".env.local" 이름으로 저장하고 값을 채우세요.
# 값은 Supabase 대시보드 > Project Settings > API 에서 복사합니다.
# https://supabase.com/dashboard/project/ofeqiqauhvcovtzjangm/settings/api
#
# 이 3개를 비워두거나 .env.local 을 만들지 않으면, 앱은 데모(목업) 데이터로 동작합니다.

# 프로젝트 URL (Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://ofeqiqauhvcovtzjangm.supabase.co

# anon public 키 (브라우저에 노출되어도 되는 공개 키)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# service_role 키 (서버 전용 비밀키 — 절대 외부에 공유하지 말 것)
SUPABASE_SERVICE_ROLE_KEY=
