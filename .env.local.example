# U-Quest 환경변수 템플릿
# ------------------------------------------------------------------
# 사용법: 이 파일을 복사해서 `.env.local` 로 만들고 값을 채운다.
#   cp .env.local.example .env.local
# (.env.local 은 git에 올라가지 않음 — .gitignore 처리됨)
#
# ⚠️ 절대 주의: 아래 값은 반드시 "U-Quest 전용" Supabase/Cloudflare 것만 사용한다.
#    캐시플로우(Cashflow) 프로젝트의 URL/키를 넣으면 DB가 섞인다. 절대 금지.
# ------------------------------------------------------------------

# --- Supabase (필수) -------------------------------------------------
# Supabase 대시보드 → 해당 프로젝트 → Settings → API 에서 복사
# 1) Project URL
NEXT_PUBLIC_SUPABASE_URL=
# 2) Project API keys → anon public (브라우저 노출 OK)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# 3) Project API keys → service_role (서버 전용, 절대 외부 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=

# --- Supabase CLI/마이그레이션용 (선택) ------------------------------
# Supabase 대시보드 → Account → Access Tokens 에서 발급
SUPABASE_ACCESS_TOKEN=

# --- Cloudflare (배포용, 선택 — 로컬 개발에는 불필요) ----------------
# Cloudflare 대시보드에서 발급. U-Quest 전용 토큰/계정만 사용.
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
